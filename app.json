{
  "expo": {
    "name": "Daily Expense Diary",
    "slug": "daily-expense-diary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F7FA"
    },
    "userInterfaceStyle": "light",
    "scheme": "dailyexpensediary",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dailyexpensediary.app"
    },
    "android": {
      "package": "com.dailyexpensediary.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#EEF5F0",
        "foregroundImage": "./assets/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "baseUrl": "/daily-expense-diary"
    },
    "extra": {
      "eas": {
        "projectId": "4ad327a3-bffc-4814-b7cf-54a53b667949"
      }
    },
    "owner": "dgkachhia",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5F7FA"
        }
      ]
    ]
  }
}
